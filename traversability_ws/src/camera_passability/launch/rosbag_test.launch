<!--
  rosbag_test.launch
  ==================
  rosbag 재생 + camera_passability 파이프라인 전체 실행.

  사용법:
    roslaunch camera_passability rosbag_test.launch bag:=/path/to/your.bag

  선택 인자:
    bag        : rosbag 파일 경로 (필수)
    rate       : 재생 속도 배율 (기본 1.0)
    loop       : 반복 재생 여부 (기본 false)
    yolo_model : YOLO 모델 경로 (기본 yolov8n.pt)

  TF 주의:
    rosbag의 tf_static에는 RealSense 내부 프레임만 들어있고 base_footprint는 없습니다.
    아래 static_transform_publisher가 base_footprint → camera_link 한 단계만 채워주면
    카메라 내부의 정확한 회전(camera_link → ... → camera_color_optical_frame)은
    rosbag tf_static이 알아서 처리합니다.

    절대 child를 camera_color_optical_frame으로 잡으면 안 됩니다 — rosbag tf_static이
    이미 그 프레임의 부모로 camera_aligned_depth_to_color_frame을 지정해놓아 다중 부모
    충돌이 생깁니다.
-->
<launch>
  <param name="use_sim_time" value="true"/>
  <!-- ── 인자 정의 ─────────────────────────────────────────────────── -->
  <arg name="bag"        default=""    doc="rosbag 파일 경로"/>
  <arg name="rate"       default="1.0" doc="재생 속도"/>
  <arg name="loop_flag" default="" doc="반복 재생 시 '--loop' 여부 전달"/>
  <arg name="yolo_model" default="yolov8n.pt"/>

  <!-- ── rosbag 재생 ──────────────────────────────────────────────── -->
  <node pkg="rosbag" type="play" name="rosbag_play"
        args="--clock $(arg bag) --rate=$(arg rate) $(arg loop_flag)"
        required="true" output="log"/>

  <!-- ── TF: base_footprint → camera_link 한 단계만 채워줌 ───────── -->
  <!--
    args 형식:  x  y  z   yaw  pitch  roll   parent  child  period_ms
    아래 값들은 PLACEHOLDER이며 실제 1:5 RC카 마운트 측정값으로 교체해야 합니다.

      x      : base_footprint 중심에서 카메라까지의 forward 거리 [m]
      y      : 좌우 오프셋 [m]. +가 LEFT. 정중앙 마운트면 0.
               (지난 테스트에서 좌측 +0.2~0.4m에 systematic 빨강 strip이 잡힌 게
                실측 y를 0으로 둬서 ground point들이 한쪽으로 몰린 결과일 수 있음 —
                실측 후 갱신 필요)
      z      : 지면에서 카메라까지 높이 [m]
      yaw    : Z축 회전 [rad]
      pitch  : Y축 회전 [rad]. 카메라가 살짝 아래를 보면 음수.
      roll   : X축 회전 [rad]. 카메라 마운트 기울어짐 보정용.

    회전 90° (광학 프레임 정렬)은 rosbag tf_static의 camera_link →
    camera_aligned_depth_to_color_frame → camera_color_optical_frame 체인이
    이미 정확히 처리하므로, 여기선 로봇-카메라 마운트 회전만 신경 쓰면 됩니다.
  -->
  <node pkg="tf" type="static_transform_publisher" name="cam_tf"
        args="0.35 0.0 0.3 0.0 -0.1 0.0 base_footprint camera_link 100"/>

  <!-- ── Traversability costmap 생성 ─────────────────────────────── -->
  <node pkg="camera_passability" type="Traversability_traversability_node.py"
        name="traversability_node" output="screen">
    <param name="yolo_model" value="$(arg yolo_model)"/>
  </node>

  <!-- ── 동적 장애물 판단 ──────────────────────────────────────────── -->
  <node pkg="camera_passability" type="camera_passability_node.py"
        name="camera_passability_node" output="screen">
    <param name="yolo_model" value="$(arg yolo_model)"/>
  </node>

  <!-- ── Local path 생성 ──────────────────────────────────────────── -->
  <node pkg="camera_passability" type="local_path_node.py"
        name="local_path_node" output="screen"/>

  <!-- ── OpenCV 시각화 ─────────────────────────────────────────────── -->
  <node pkg="camera_passability" type="visualizer_node.py"
        name="visualizer_node" output="screen"/>

</launch>
